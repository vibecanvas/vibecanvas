{
  "name": "vibecanvas",
  "version": "0.2.2",
  "private": true,
  "description": "Run your agents in an infinite canvas",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "@automerge/automerge": "3.2.5",
    "@automerge/automerge-repo": "2.5.5",
    "@automerge/automerge-repo-network-broadcastchannel": "2.5.5",
    "@automerge/automerge-repo-network-websocket": "2.5.5",
    "@automerge/automerge-repo-storage-indexeddb": "2.5.5",
    "@orpc/client": "1.13.13",
    "@orpc/contract": "1.13.13",
    "@orpc/server": "1.13.13",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "drizzle-zod": "0.8.3",
    "typescript": "5.9.3",
    "zod": "4.3.6",
    "@kobalte/core": "^0.13.11",
    "lucide-solid": "^1.7.0",
    "solid-js": "^1.9.12"
  },
  "scripts": {
    "postinstall": "node scripts/patch-automerge-repo-throttle.mjs",
    "test": "bun run --parallel --filter '@vibecanvas/cli' --filter '@vibecanvas/web' --filter '@vibecanvas/frontend' --filter '@vibecanvas/api-canvas' --filter '@vibecanvas/api-canvas-cmd' --filter '@vibecanvas/api-db' --filter '@vibecanvas/api-file' --filter '@vibecanvas/api-filesystem' --filter '@vibecanvas/api-filetree' --filter '@vibecanvas/api-notification' --filter '@vibecanvas/api-pty' --filter '@vibecanvas/canvas-cmds' --filter '@vibecanvas/runtime' --filter '@vibecanvas/service-automerge' --filter '@vibecanvas/service-db' --filter '@vibecanvas/service-event-publisher' --filter '@vibecanvas/service-filesystem' --filter '@vibecanvas/service-pty' --filter '@vibecanvas/shared-functions' --filter '@vibecanvas/tapable' test",
    "test:ci:docker": "docker run --rm -it --platform linux/amd64 -v \"$PWD\":/repo -w /repo ubuntu:24.04 bash -lc 'export DEBIAN_FRONTEND=noninteractive && apt-get update && apt-get install -y curl unzip git ca-certificates && curl -fsSL https://bun.sh/install | bash && export BUN_INSTALL=/root/.bun && export PATH=$BUN_INSTALL/bin:$PATH && bun --version && bun install --frozen-lockfile && bun run test'",
    "test:binary": "bun run scripts/test-binary.ts",
    "build": "bun run scripts/build.ts",
    "build:single": "bun run scripts/build.ts --single",
    "web:dev": "bun --filter @vibecanvas/web dev",
    "web:build": "bun --filter @vibecanvas/web build",
    "publish:npm": "bun run scripts/publish-npm.ts",
    "release:github": "bun run scripts/release.ts",
    "version:update": "bun run scripts/update-version.ts",
    "dev": "bun run --parallel --filter '*' dev",
    "client:dev": "cd apps/frontend && bun run dev",
    "server:dev": "cd apps/cli && bun run --watch src/main.ts serve",
    "server:prod": "cd apps/cli && NODE_ENV=production bun run src/main.ts serve --port 7496"
  },
  "keywords": [],
  "license": "MIT",
  "devDependencies": {
    "bun-types": "^1.3.11"
  },
  "overrides": {
    "@codemirror/language": "6.12.3",
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.41.0"
  },
  "dependencies": {
    "@lastolivegames/becsy": "^0.15.5",
    "bun-plugin-tailwind": "^0.1.2",
    "handlebars": "^4.7.9",
    "pixi.js": "^8.17.1"
  }
}